using pandaC

# ==========================================
# ЧАСТЬ 1: УЖЕ РЕАЛИЗОВАНО (База и алгоритмы)
# ==========================================
def calculate_stats(numbers):
    total = 0
    for n in numbers:
        total += n
    return total / len(numbers)

def math_and_types():
    string_val = "42"
    number = int(string_val)
    number += 8

    if float(number) >= 50.0:
        print("Success: number is", number)
    else:
        print("Failed")

