using pandaC

def main():
    # Указываем тип списка (list<int64>), так как C++ требует строгую типизацию
    list<int64> my_arr = [10, 20, 30]

    # Доступ по индексу (Lexer -> IndexAccess)
    int64 first = my_arr[0]
    int64 second = my_arr[1]
    int64 third = 1

    print("First element is:")
    print(first)

    print("Math with array elements:")
    print(first + second)
